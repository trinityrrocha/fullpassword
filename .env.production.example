# FullPassword - Exemplo de configuracao de producao

DB_HOST=db
DB_PORT=5432
DB_USER=fullpassword_user
DB_PASSWORD=GERE_UMA_SENHA_ALEATORIA_FORTE
DB_NAME=fullpassword_db

PORT=3000
NODE_ENV=production
JWT_SECRET=GERE_128_CARACTERES_HEXADECIMAIS
JWT_EXPIRES_IN=8h
ADMIN_BOOTSTRAP_TOKEN=GERE_64_CARACTERES_HEXADECIMAIS
SUPER_ADMIN_EMAIL=superadmin@exemplo.com.br
APP_ORIGIN=https://SEU_DOMINIO.com.br

VITE_API_URL=https://SEU_DOMINIO.com.br/api
NGINX_CONF_PATH=./docker/nginx.runtime.conf

# Backup v2 (valores padrão)
BACKUP_CHUNK_SIZE_MB=50
BACKUP_MAX_UPLOAD_MB=2048
BACKUP_TEMP_DIR=/tmp/fullpassword-backups
BACKUP_RESTORE_TIMEOUT_MS=1800000
