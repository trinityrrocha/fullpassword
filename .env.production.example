# ==========================================
# FullPassword - Configurações de Produção
# ==========================================
# Este arquivo é gerado automaticamente pelo install.sh
# Mantenha-o seguro e NUNCA comite no repositório!

# Banco de Dados PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USER=fullpassword_user
# Gerado automaticamente no install.sh (ex: aB3dE5fG7hI9jK1lM3nO5pQ7)
DB_PASSWORD=SUA_SENHA_FORTE_GERADA_AQUI
DB_NAME=fullpassword_db

# Backend Node.js
PORT=3000
NODE_ENV=production
# Gerado automaticamente no install.sh (ex: 64 caracteres hex)
JWT_SECRET=SEU_JWT_SECRET_GERADO_AQUI
JWT_EXPIRES_IN=8h

# Frontend React/Vite
# URL pública da API para o frontend consumir
VITE_API_URL=https://SEU_DOMINIO.com.br/api
